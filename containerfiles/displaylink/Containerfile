ADD https://negativo17.org/repos/fedora-multimedia.repo /etc/yum.repos.d/fedora-multimedia.repo

RUN --mount=type=cache,target=/var/cache/dnf \
    set -eux; \
    FEDORA_VER="$(rpm -E %fedora)"; \
    AKMOD_URL="https://negativo17.org/repos/multimedia/fedora-${FEDORA_VER}/x86_64/akmod-evdi-1.14.15-1.fc${FEDORA_VER}.x86_64.rpm"; \
    \
    dnf5 -y --setopt=install_weak_deps=False install \
    akmods \
    displaylink \
    libevdi \
    xorg-x11-displaylink \
    kernel-devel \
    kernel-devel-matched && \
    \
    curl -L "$AKMOD_URL" -o /tmp/akmod-evdi.rpm && \
    rpm -Uvh --nopost --noposttrans /tmp/akmod-evdi.rpm && \
    rm -f /tmp/akmod-evdi.rpm && \
    dnf5 clean all